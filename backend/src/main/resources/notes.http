##################################################
#                DANCE CONTROLLER
##################################################

### GET ALL DANCES (FREE, PREMIUM, ADMIN)
GET {{host}}/api/dances/all
Authorization: Bearer {{token_free}}

###

### GET DANCE BY ID (PUBLIC - sin seguridad)
GET {{host}}/api/dances/8
Authorization: Bearer {{token_free}}

###

### CREATE DANCE (ADMIN ONLY)
POST {{host}}/api/dances/save
Authorization: Bearer {{token_admin}}
Content-Type: application/json

{
  "name": "Flamenco",
  "region": "Andalucía",
  "description": "Baile tradicional",
  "videoUrl": "https://youtube.com/flamenco"
}

###

### DELETE DANCE (ADMIN ONLY)
DELETE {{host}}/api/dances/14
Authorization: Bearer {{token_admin}}

###

### ❌ TEST ERROR (FREE intentando crear dance)
POST {{host}}/api/dances/save
Authorization: Bearer {{token_free}}
Content-Type: application/json

{
  "name": "Error Dance",
  "region": "Test",
  "description": "No debería funcionar",
  "videoUrl": "test"
}

###

